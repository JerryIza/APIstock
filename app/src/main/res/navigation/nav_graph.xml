<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/marketMoversFragment">

    <fragment
        android:id="@+id/marketMoversFragment"
        android:name="com.example.apistock.ui.fragments.MarketMoversFragment"
        android:label="MarketMoversFragment"
        tools:layout="@layout/market_movers_fragment"
        >

        <action
            android:id="@+id/action_marketMoversFragment_to_stockDetailsFragment"
            app:destination="@id/stockDetailsFragment" />
        <action
            android:id="@+id/action_marketMoversFragment_to_searchFragment"
            app:destination="@id/searchFragment" />
    </fragment>

    <fragment
        android:id="@+id/stockDetailsFragment"
        android:name="com.example.apistock.ui.fragments.SymbolDetailsFragment"
        android:label="SymbolDetailsFragment"
        tools:layout="@layout/symbol_details_fragment"
        />
    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.apistock.ui.fragments.SearchFragment"
        android:label="SearchFragment"
        tools:layout="@layout/search_fragment"
        >
        <action
            android:id="@+id/action_searchFragment_to_stockDetailsFragment"
            app:destination="@id/stockDetailsFragment"
            app:popUpTo="@id/stockDetailsFragment"
            app:popUpToInclusive="false" />
    </fragment>
</navigation>